{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"],
    "rootDir": "..",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "baseUrl": "..",
    "paths": {
      "@shared/*": ["shared/*"]
    }
  },
  "include": ["src/**/*.ts", "../shared/**/*.ts", "../prisma/**/*.ts"]
}
