# ---------------------------------------------------------------------------
# Alper Chores — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit a real `.env`.
# ---------------------------------------------------------------------------

# Node environment: development | production | test
NODE_ENV=development

# Port the production server binds to. Railway injects PORT automatically;
# do not hard-code a production port. 3000 is only the local default.
PORT=3000

# PostgreSQL connection string. On Railway this is provided automatically as
# DATABASE_URL by the PostgreSQL plugin. Locally, point it at your own Postgres.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public

# Household timezone used for generating the weekly schedule and local dates.
HOUSEHOLD_TIMEZONE=Asia/Jerusalem

# Secret placeholder reserved for future session/PIN support. Not required for
# version 1, but generate a long random value so it is ready if needed.
SESSION_SECRET=replace-with-a-long-random-value

# Comma-separated list of allowed CORS origins for local cross-port dev.
# In production the app is served same-origin, so this can stay empty.
CORS_ORIGINS=http://localhost:5173
